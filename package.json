{
  "name": "games-db",
  "version": "1.0.0",
  "description": "Games Database - Full Stack Application",
  "private": true,
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "install:all": "cd server && npm install && cd ../client && npm install",
    "stop": "pkill -f \"tsx watch\" || true && pkill -f \"next dev\" || true"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}